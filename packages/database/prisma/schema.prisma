// Defining Schema with Prisma ORM

// Generator client Typescript
generator client {
  provider = "prisma-client-js"
}

// Connect to database
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// enum Role
enum Role {
  USER
  ADMIN
  VALIDATOR
  AUDITOR
  PIC
}

// enum Token Type
enum TokenType {
  ACTIVATION
  RESET_PASSWORD
}

// enum Proposal Status
enum ProposalStatus {
  PENDING
  APPROVED
  DRAWABLE
  MILESTONE_ACHIEVED
  FROZEN
  COMPLETED
  FRAUD_CONFIRMED 
}


// enum Integrity
enum Integrity {
  VERIFIED
  HASH_MISMATCH
  ORPHAN
}

// enum displayTab
enum DisplayTab {
  ACTIVE 
  FINISHED 
  FLAGGED 
  FRAUD
}

// enum Milestone Status
enum MilestoneStatus {
  PLANNED
  RELEASED
  ACHIEVED
}

// enum Signer Role
enum SignerRole {
  ADMIN
  VALIDATOR
  AUDITOR
}

// enum Reputation Reason
enum ReputationReason {
  PROGRAM_COMPLETED
  MILESTONE_FINALIZED
  FRAUD_PROVEN
  FALSE_FREEZE
  VALID_FREEZE
}

// enum Freeze Result
enum FreezeResult {
  PENDING
  CLEARED
  FRAUD_PROVEN
  UNRESOLVED 
}
// enum Role Change Type
enum RoleChangeType {
  PIC_GRANTED
  PIC_REVOKED
  ROLE_GRANTED      
  ROLE_REVOKED      
}


// User Model Data
model User {
  id                  String    @id @default(cuid())
  username            String    @unique
  email               String    @unique
  passwordHash        String
  isActive            Boolean   @default(false)
  isVerified          Boolean   @default(false)
  role                Role      @default(USER)
  reputationScore     Int       @default(50)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  walletAddress       String?   @unique
  name                String?
  nik                 String?   @unique
  nip                 String?   @unique
  institution         String?
  position            String?
  birthPlace          String?
  birthDate           DateTime?
  address             String?
  phone               String?
  nationality         String?
  profilePictureURL   String?
  verificationTokens  VerificationToken[]
  programs            Program[]
  roleVoteBallots     RoleVoteBallot[]
  unfreezeBallots     UnfreezeVoteBallot[]
  reputationLogs      ReputationLog[]

  @@index([role])
}

// Reputation Log Model Data
model ReputationLog {
  id                  String     @id  @default(cuid())
  change              Int
  reason              ReputationReason
  scoreAfter          Int
  programId           Int?
  program             Program?   @relation(fields: [programId], references: [programId])
  userId              String
  user                User       @relation(fields: [userId], references: [id])
  createdAt           DateTime   @default(now())

  @@index([userId])
  @@index([programId])
}

// Verification Model Data
model VerificationToken {
  id                  String    @id @default(cuid())
  tokenHash           String    @unique
  type                TokenType
  expiresAt           DateTime
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt           DateTime  @default(now())
}

// Program Model Data
model Program {
  programId           Int       @id  @default(autoincrement())
  programHash         String
  picWallet           String
  totalBudget         String
  totalAllocatedSoFar String    @default("0")
  milestoneCount      Int
  currentMilestone    Int       @default(0)
  status              ProposalStatus  @default(PENDING)
  submittedAt         DateTime?
  title               String?
  description         String?
  province            String?
  regency             String?
  district            String?
  locationAddress     String?
  executorName        String?
  executorRegistration String?
  category            String?
  institutionName     String?
  fiscalYear          Int?
  plannedStartDate    DateTime?
  plannedEndDate      DateTime?
  ipfsCid             String?
  integrity           Integrity   @default(VERIFIED)
  displayTab          DisplayTab  @default(ACTIVE)
  isOrphan            Boolean     @default(false)
  isOnChain           Boolean     @default(false)
  txHash              String?
  picId               String?
  pic                 User?       @relation(fields: [picId], references: [id])
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  milestones          Milestone[]
  withdrawals         WithdrawalRecord[]
  unfreezeVote        UnfreezeVote?
  freezeOutcome       FreezeOutcome?
  reputationLogs      ReputationLog[]

  @@index([displayTab])
  @@index([status])
  @@index([programHash])
  @@index([picId])
  @@index([isOnChain])
}

// Milestone Model Data
model Milestone {
  id                  String      @id   @default(cuid())
  title               String?
  description         String?
  evidenceURL         String?
  evidenceHash        String?
  status              MilestoneStatus   @default(PLANNED)
  milestoneIndex      Int        
  milestoneBudget     String      @default("0")
  programId           Int 
  program             Program     @relation(fields: [programId], references: [programId])
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  signatures          MilestoneSignature[]

  @@unique([programId, milestoneIndex])
}

// Milestone Signature for EIP 712 Data
model MilestoneSignature {
  id                  String      @id   @default(cuid())
  signerWallet        String      
  signerRole          SignerRole
  signature           String
  signedAt            DateTime    @default(now())
  milestoneId         String
  milestone           Milestone   @relation(fields: [milestoneId], references: [id])

  @@unique([milestoneId, signerWallet])
  @@unique([milestoneId, signerRole]) 
}

// Withdrawl Record Model Data
model WithdrawalRecord {
  id                  String      @id   @default(cuid())
  amount              String
  recipientName       String
  description         String
  timestamp           DateTime
  txHash              String?
  picWallet           String
  programId           Int
  program             Program     @relation(fields: [programId], references: [programId])
  
  @@index([programId])
}

// Role Vote Model Data
model RoleVote {
  voteId              Int         @id
  candidate           String
  roleToTarget        SignerRole
  voteCount           Int         @default(0)
  isDevote            Boolean     @default(false)
  executed            Boolean     @default(false)
  ballots             RoleVoteBallot[]
}

// Role Vote Ballot Model Data
model RoleVoteBallot {
  id                  String    @id @default(cuid())
  roleVoteId          Int
  roleVote            RoleVote  @relation(fields: [roleVoteId], references: [voteId])
  voterId             String
  voter               User      @relation(fields: [voterId], references: [id])
  votedAt             DateTime  @default(now())

  @@unique([roleVoteId, voterId])
}

// Unfreeze Vote Model Data
model UnfreezeVote {
  id                 String     @id   @default(cuid())
  programId          Int        @unique
  picWallet          String     
  program            Program    @relation(fields: [programId], references: [programId])
  approveVotes       Int        @default(0)
  rejectVotes        Int        @default(0)
  appealStartedAt    DateTime?
  resolved           Boolean    @default(false)
  createdAt          DateTime   @default(now())
  txHash             String?
  ballots            UnfreezeVoteBallot[]
}

// Unfreeze Vote Ballot Model Data
model UnfreezeVoteBallot {
  id                 String     @id   @default(cuid())
  unfreezeVoteId     String
  unfreezeVote       UnfreezeVote   @relation(fields: [unfreezeVoteId], references: [id])
  voterId            String
  voter              User       @relation(fields: [voterId], references: [id])
  approve            Boolean 
  votedAt            DateTime   @default(now())

  @@unique([unfreezeVoteId, voterId])
}

// Freeze Outcome Model Data
model FreezeOutcome {
  id            String       @id @default(cuid())
  auditorWallet String                                    
  outcome       FreezeResult @default(PENDING)
  frozenAt      DateTime
  resolvedAt    DateTime?                                 
  programId     Int          @unique                      
  program       Program      @relation(fields: [programId], references: [programId])
  createdAt     DateTime     @default(now())
  txHash        String?
}

model RoleChangeLog {
  id            String          @id   @default(cuid())
  changeType    RoleChangeType
  targetWallet  String      
  targetRole    String
  actorWallet   String?
  txHash        String?
  createdAt     DateTime        @default(now())

  @@index([targetWallet])
  @@index([actorWallet])
}