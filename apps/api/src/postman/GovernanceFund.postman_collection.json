    },
    {
      "name": "7. Uploads (Cloudinary + IPFS)",
      "description": "Upload gambar/dokumen. Program/milestone/withdrawal butuh role PIC (pemilik); user avatar/banner self-scoped (user login apa pun). Pilih file di field form-data 'file' sebelum Send. Butuh CLOUDINARY_* + PINATA_JWT di apps/api/.env.",
      "item": [
        {
          "name": "Program Image (PIC → Cloudinary → programURLs)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{picToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            },
            "url": {
              "raw": "{{apiUrl}}/uploads/program/{{programId}}/image",
              "host": ["{{apiUrl}}"],
              "path": ["uploads", "program", "{{programId}}", "image"]
            },
            "description": "form-data 'file' = jpg/png/webp (≤5MB). Append ke Program.programURLs. Return { url, publicId, programURLs }."
          }
        },
        {
          "name": "Program Pin Data (PIC → IPFS → ipfsCid)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{picToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/uploads/program/{{programId}}/pin-data",
              "host": ["{{apiUrl}}"],
              "path": ["uploads", "program", "{{programId}}", "pin-data"]
            },
            "description": "Tanpa body. Pin JSON kanonik program ke Pinata, simpan Program.ipfsCid. Return { cid, gatewayUrl }."
          }
        },
        {
          "name": "Milestone Evidence (PIC → IPFS + sha256)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{picToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            },
            "url": {
              "raw": "{{apiUrl}}/uploads/milestone/{{milestoneId}}/evidence",
              "host": ["{{apiUrl}}"],
              "path": ["uploads", "milestone", "{{milestoneId}}", "evidence"]
            },
            "description": "form-data 'file' = pdf/image (≤10MB). Milestone harus PLANNED. Set evidenceURL+evidenceHash. Return { cid, gatewayUrl, evidenceHash } — evidenceHash dipakai EIP-712 + executeMilestoneRelease."
          }
        },
        {
          "name": "Withdrawal Receipt (PIC → Cloudinary → receiptUrl)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{picToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            },
            "url": {
              "raw": "{{apiUrl}}/uploads/withdrawal/{{withdrawalId}}/receipt",
              "host": ["{{apiUrl}}"],
              "path": ["uploads", "withdrawal", "{{withdrawalId}}", "receipt"]
            },
            "description": "form-data 'file' = jpg/png/webp (≤5MB). Set WithdrawalRecord.receiptUrl. Isi {{withdrawalId}} dari id WithdrawalRecord (setelah webhook OnChainWithdrawalLogged)."
          }
        },
        {
          "name": "User Avatar (self → Cloudinary → profilePictureURL)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            },
            "url": {
              "raw": "{{apiUrl}}/uploads/user/avatar",
              "host": ["{{apiUrl}}"],
              "path": ["uploads", "user", "avatar"]
            },
            "description": "User login apa pun (pakai {{token}} default). form-data 'file' = image ≤5MB. Set profilePictureURL sendiri."
          }
        },
        {
          "name": "User Banner (self → Cloudinary → profileBannerURL)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            },
            "url": {
              "raw": "{{apiUrl}}/uploads/user/banner",
              "host": ["{{apiUrl}}"],
              "path": ["uploads", "user", "banner"]
            },
            "description": "User login apa pun. form-data 'file' = image ≤5MB. Set profileBannerURL sendiri."
          }
        }
      ]
    }
  ]
