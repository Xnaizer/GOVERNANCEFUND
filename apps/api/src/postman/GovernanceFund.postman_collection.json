    {
      "name": "6. Webhook Simulation",
      "description": "Mock on-chain events. Folder pre-request script computes the x-alchemy-signature HMAC over the raw body using {{webhookSecret}} (= ALCHEMY_WEBHOOK_SECRET) from the selected environment. Body must stay in the { eventName, args, txHash } mock shape (Path 1 of the webhook route). Wallets in args must already exist as bound users for role/reputation handlers to resolve them.",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Compute Alchemy-style HMAC-SHA256 over the exact raw body sent.",
              "const raw = pm.variables.replaceIn(pm.request.body.raw);",
              "const secret = pm.environment.get('webhookSecret');",
              "if (!secret || String(secret).indexOf('REPLACE') === 0) { console.warn('Set webhookSecret in the environment to ALCHEMY_WEBHOOK_SECRET'); }",
              "const sig = CryptoJS.HmacSHA256(raw, secret).toString(CryptoJS.enc.Hex);",
              "pm.request.headers.upsert({ key: 'x-alchemy-signature', value: sig });",
              "pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });"
            ]
          }
        }
      ],
