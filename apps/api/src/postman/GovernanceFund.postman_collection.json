            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/auth/verify-email?token={{verifyToken}}",
              "host": ["{{apiUrl}}"],
              "path": ["auth", "verify-email"],
              "query": [{ "key": "token", "value": "{{verifyToken}}" }]
