        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "if (j && j.data && j.data.token) {",
                  "  pm.environment.set('token', j.data.token);",
                  "  console.log('Saved token to environment');",
                  "}",
                  "pm.test('has token', () => pm.expect(j.data && j.data.token).to.be.ok);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"pic@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{apiUrl}}/auth/login",
              "host": ["{{apiUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Saves data.token to the `token` environment variable. To collect role tokens, log in as each account and copy `token` into adminToken/picToken/validatorToken/auditorToken."
