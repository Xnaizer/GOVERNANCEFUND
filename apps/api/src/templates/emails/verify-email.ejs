<!DOCTYPE html>
<html lang="id" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="color-scheme" content="light only" />
  <meta name="supported-color-schemes" content="light only" />
  <title>Verifikasi Email</title>
  <!--[if mso]>
  <noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript>
  <![endif]-->
  <style>
    body, table, td, a { -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%; }
    table, td { mso-table-lspace:0pt; mso-table-rspace:0pt; }
    img { -ms-interpolation-mode:bicubic; border:0; line-height:100%; outline:none; text-decoration:none; }
    table { border-collapse:collapse !important; }
    body { margin:0 !important; padding:0 !important; width:100% !important; }
    a { color:#4899EA; }
    @media screen and (max-width:620px) {
      .container { width:100% !important; }
      .px { padding-left:24px !important; padding-right:24px !important; }
      .py-header { padding:34px 24px 28px !important; }
      .h1 { font-size:22px !important; }
    }
  </style>
</head>

<body style="margin:0;padding:0;background-color:#eef1f6;">
  <div style="display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;line-height:1px;color:#eef1f6;opacity:0;">
    Konfirmasi email untuk mengaktifkan akun GovernanceFund Anda. Tautan berlaku 24 jam.
  </div>

  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color:#eef1f6;">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table role="presentation" class="container" cellpadding="0" cellspacing="0" border="0" width="600" style="width:600px;max-width:600px;background-color:#ffffff;border-radius:20px;overflow:hidden;box-shadow:0 10px 40px rgba(11,18,32,0.10);">

          <!-- HEADER -->
          <tr>
            <td class="py-header" align="center" style="padding:42px 48px 32px;background-color:#0b1220;background-image:linear-gradient(135deg,#122036 0%,#0b1220 60%,#0a0f1c 100%);">
              <div style="font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:13px;font-weight:800;letter-spacing:4px;color:#ffffff;">GOVERNANCE</div>
              <div style="margin-top:2px;font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:13px;font-weight:800;letter-spacing:7px;color:#67F3CE;">FUND</div>
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:16px auto 0;">
                <tr><td width="120" height="3" style="width:120px;height:3px;background-color:#4899EA;background-image:linear-gradient(90deg,#67F3CE,#4899EA);font-size:0;line-height:0;border-radius:2px;">&nbsp;</td></tr>
              </table>
              <div style="margin-top:16px;font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#8fa0c4;">
                Aktivasi Akun
              </div>
            </td>
          </tr>

          <!-- BODY -->
          <tr>
            <td class="px" style="padding:44px 48px 8px;">
              <h1 class="h1" style="margin:0;text-align:center;font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:24px;font-weight:700;letter-spacing:-0.3px;color:#0b1220;">
                Verifikasi alamat email Anda
              </h1>
              <p style="margin:28px 0 0;font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:16px;line-height:27px;color:#475069;">
                Halo <strong style="color:#0b1220;"><%= username %></strong>,
              </p>
              <p style="margin:14px 0 0;font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:16px;line-height:27px;color:#475069;">
                Selamat datang di <strong style="color:#0b1220;">GovernanceFund</strong>. Akun Anda berhasil dibuat. Untuk menyelesaikan pendaftaran dan mengamankan akses, konfirmasi alamat email Anda lewat tombol di bawah.
              </p>
            </td>
          </tr>

          <!-- BUTTON -->
          <tr>
            <td class="px" align="center" style="padding:32px 48px 8px;">
              <!--[if mso]>
              <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="<%= verifyUrl %>" style="height:52px;v-text-anchor:middle;width:260px;" arcsize="24%" strokecolor="#2f79d4" fillcolor="#4899EA">
                <w:anchorlock/>
                <center style="color:#ffffff;font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:15px;font-weight:bold;">Verifikasi Email</center>
              </v:roundrect>
              <![endif]-->
              <!--[if !mso]><!-->
              <a href="<%= verifyUrl %>" style="display:inline-block;padding:16px 44px;background-color:#4899EA;background-image:linear-gradient(135deg,#4899EA 0%,#2f79d4 100%);border-radius:12px;font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:15px;font-weight:700;letter-spacing:0.3px;color:#ffffff;text-decoration:none;box-shadow:0 8px 20px rgba(72,153,234,0.35);">
                Verifikasi Email
              </a>
              <!--<![endif]-->
            </td>
          </tr>

          <!-- SECURITY BOX -->
          <tr>
            <td class="px" style="padding:32px 48px 0;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color:#f4f7fc;border:1px solid #e2e8f2;border-left:3px solid #4899EA;border-radius:12px;">
                <tr>
                  <td style="padding:22px 24px;">
                    <div style="font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#2f79d4;">Informasi Keamanan</div>
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-top:14px;">
                      <tr>
                        <td valign="top" width="14" style="font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:14px;line-height:23px;color:#4899EA;">&bull;</td>
                        <td style="font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:14px;line-height:23px;color:#56607a;">Tautan verifikasi ini kedaluwarsa dalam <strong style="color:#0b1220;">24 jam</strong>.</td>
                      </tr>
                      <tr>
                        <td valign="top" width="14" style="padding-top:8px;font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:14px;line-height:23px;color:#4899EA;">&bull;</td>
                        <td style="padding-top:8px;font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:14px;line-height:23px;color:#56607a;">Demi keamanan, tautan hanya bisa dipakai sekali.</td>
                      </tr>
                      <tr>
                        <td valign="top" width="14" style="padding-top:8px;font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:14px;line-height:23px;color:#4899EA;">&bull;</td>
                        <td style="padding-top:8px;font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:14px;line-height:23px;color:#56607a;">Jika Anda tidak membuat akun ini, abaikan saja email ini.</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- ACCOUNT INFO -->
          <tr>
            <td class="px" style="padding:16px 48px 0;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="border:1px solid #e2e8f2;border-radius:12px;">
                <tr>
                  <td style="padding:20px 24px;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                      <tr>
                        <td style="font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:14px;line-height:22px;color:#8a94a6;">Username</td>
                        <td align="right" style="font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:14px;line-height:22px;font-weight:600;color:#0b1220;"><%= username %></td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- FALLBACK LINK -->
          <tr>
            <td class="px" style="padding:28px 48px 0;">
              <p style="margin:0 0 12px;font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:13px;line-height:21px;color:#8a94a6;">
                Jika tombol di atas tidak berfungsi, salin dan tempel URL berikut ke peramban Anda:
              </p>
              <div style="background-color:#f4f7fc;border:1px solid #e2e8f2;border-radius:10px;padding:14px 16px;word-break:break-all;font-family:'Courier New',Courier,monospace;font-size:13px;line-height:21px;color:#2f79d4;">
                <%= verifyUrl %>
              </div>
            </td>
          </tr>

          <!-- HELP -->
          <tr>
            <td class="px" style="padding:30px 48px 40px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                <tr><td height="1" style="height:1px;background-color:#e6eaf1;font-size:0;line-height:0;">&nbsp;</td></tr>
              </table>
              <div style="margin-top:24px;font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:15px;font-weight:700;color:#0b1220;">Butuh bantuan?</div>
              <p style="margin:10px 0 0;font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:14px;line-height:23px;color:#56607a;">
                Bila mengalami kendala saat verifikasi, balas saja email ini dan tim kami akan dengan senang hati membantu.
              </p>
            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td align="center" style="background-color:#0b1220;padding:28px 40px;">
              <div style="font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:12px;font-weight:800;letter-spacing:3px;color:#ffffff;">GOVERNANCE</div>
              <div style="margin-top:2px;font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:12px;font-weight:800;letter-spacing:6px;color:#67F3CE;">FUND</div>
              <p style="margin:18px 0 0;font-family:'Segoe UI',Helvetica,Arial,sans-serif;font-size:12px;line-height:20px;color:#7585a6;">
                &copy; <%= year %> GovernanceFund &middot; Proyek akademik &middot; Base Sepolia
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
