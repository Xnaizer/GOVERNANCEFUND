<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="color-scheme" content="light only" />
  <meta name="supported-color-schemes" content="light only" />
  <title>Verify Your Email</title>
  <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings>
        <o:PixelsPerInch>96</o:PixelsPerInch>
      </o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <![endif]-->
  <style>
    /* Client resets */
    body, table, td, a { -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%; }
    table, td { mso-table-lspace:0pt; mso-table-rspace:0pt; }
    img { -ms-interpolation-mode:bicubic; border:0; line-height:100%; outline:none; text-decoration:none; }
    table { border-collapse:collapse !important; }
    body { margin:0 !important; padding:0 !important; width:100% !important; }

    a { color:#9C7C3C; }

    @media screen and (max-width:620px) {
      .container { width:100% !important; }
      .px { padding-left:28px !important; padding-right:28px !important; }
      .py-header { padding:36px 28px 30px !important; }
      .h1 { font-size:24px !important; }
    }
  </style>
</head>

<body style="margin:0;padding:0;background-color:#eceef3;">

  <!-- Preheader (hidden) -->
  <div style="display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;line-height:1px;color:#eceef3;opacity:0;">
    Confirm your email to activate your GovernanceFund account. This link expires in 24 hours.
  </div>

  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color:#eceef3;">
    <tr>
      <td align="center" style="padding:40px 16px;">

        <table role="presentation" class="container" cellpadding="0" cellspacing="0" border="0" width="600" style="width:600px;max-width:600px;background-color:#ffffff;border-radius:18px;overflow:hidden;box-shadow:0 8px 30px rgba(15,27,61,0.08);">

          <!-- HEADER -->
          <tr>
            <td class="py-header" align="center" style="padding:44px 48px 34px;background-color:#0f1b3d;background-image:linear-gradient(135deg,#16254d 0%,#0f1b3d 60%,#0b1430 100%);">



              <!-- Wordmark -->
              <div style="margin-top:5px;font-family:Georgia,'Times New Roman',serif;font-size:25px;font-weight:700;letter-spacing:0.5px;color:#ffffff;">
                GovernanceFund
              </div>

              <!-- Gold divider -->
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:14px auto 0;">
                <tr><td width="48" height="2" style="width:128px;height:2px;background-color:#c2a35a;font-size:0;line-height:0;">&nbsp;</td></tr>
              </table>

              <div style="margin-top:16px;font-family:Helvetica,Arial,sans-serif;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#aebbd6;">
                Transparent Institutional Funding
              </div>

            </td>
          </tr>

          <!-- BODY -->
          <tr>
            <td class="px" style="padding:46px 48px 12px;">

              <h1 class="h1" style="margin:0;text-align:center;font-family:Georgia,'Times New Roman',serif;font-size:23px;font-weight:700;color:#101c3a;">
                Verify your email address
              </h1>

              <p style="margin:30px 0 0;font-family:Helvetica,Arial,sans-serif;font-size:16px;line-height:27px;color:#3f495c;">
                Hi <strong style="color:#101c3a;"><%= username %></strong>,
              </p>

              <p style="margin:16px 0 0;font-family:Helvetica,Arial,sans-serif;font-size:16px;line-height:27px;color:#3f495c;">
                Welcome to <strong style="color:#101c3a;">GovernanceFund</strong>. Your account has been created successfully. To complete your registration and secure your access, please confirm your email address using the button below.
              </p>

            </td>
          </tr>

          <!-- BUTTON -->
          <tr>
            <td class="px" align="center" style="padding:34px 48px 8px;">
              <!--[if mso]>
              <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="<%= verifyUrl %>" style="height:52px;v-text-anchor:middle;width:260px;" arcsize="20%" strokecolor="#c2a35a" fillcolor="#0f1b3d">
                <w:anchorlock/>
                <center style="color:#ffffff;font-family:Helvetica,Arial,sans-serif;font-size:15px;font-weight:bold;letter-spacing:0.5px;">Verify Email Address</center>
              </v:roundrect>
              <![endif]-->
              <!--[if !mso]><!-->
              <a href="<%= verifyUrl %>" style="display:inline-block;padding:16px 40px;background-color:#0f1b3d;border:1.5px solid #c2a35a;border-radius:10px;font-family:Helvetica,Arial,sans-serif;font-size:15px;font-weight:700;letter-spacing:0.5px;color:#ffffff;text-decoration:none;">
                Verify Email Address
              </a>
              <!--<![endif]-->
            </td>
          </tr>

          <!-- SECURITY BOX -->
          <tr>
            <td class="px" style="padding:34px 48px 0;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color:#f7f8fb;border:1px solid #e4e7ee;border-left:3px solid #c2a35a;border-radius:10px;">
                <tr>
                  <td style="padding:22px 24px;">
                    <div style="font-family:Helvetica,Arial,sans-serif;font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#9c7c3c;">
                      Security Information
                    </div>
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-top:14px;">
                      <tr>
                        <td valign="top" width="14" style="font-family:Helvetica,Arial,sans-serif;font-size:14px;line-height:23px;color:#c2a35a;">&bull;</td>
                        <td style="font-family:Helvetica,Arial,sans-serif;font-size:14px;line-height:23px;color:#56607a;">This verification link will expire in <strong style="color:#101c3a;">24 hours</strong>.</td>
                      </tr>
                      <tr>
                        <td valign="top" width="14" style="padding-top:8px;font-family:Helvetica,Arial,sans-serif;font-size:14px;line-height:23px;color:#c2a35a;">&bull;</td>
                        <td style="padding-top:8px;font-family:Helvetica,Arial,sans-serif;font-size:14px;line-height:23px;color:#56607a;">For your security, this link can only be used once.</td>
                      </tr>
                      <tr>
                        <td valign="top" width="14" style="padding-top:8px;font-family:Helvetica,Arial,sans-serif;font-size:14px;line-height:23px;color:#c2a35a;">&bull;</td>
                        <td style="padding-top:8px;font-family:Helvetica,Arial,sans-serif;font-size:14px;line-height:23px;color:#56607a;">If you didn&rsquo;t create this account, you can safely ignore this email.</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- ACCOUNT INFO -->
          <tr>
            <td class="px" style="padding:18px 48px 0;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="border:1px solid #e4e7ee;border-radius:10px;">
                <tr>
                  <td style="padding:22px 24px;">
                    <div style="font-family:Helvetica,Arial,sans-serif;font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#9c7c3c;">
                      Account Information
                    </div>
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-top:16px;">
                      <tr>
                        <td style="font-family:Helvetica,Arial,sans-serif;font-size:14px;line-height:22px;color:#8a94a6;">Username</td>
                        <td align="right" style="font-family:Helvetica,Arial,sans-serif;font-size:14px;line-height:22px;font-weight:600;color:#101c3a;"><%= username %></td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- FALLBACK LINK -->
          <tr>
            <td class="px" style="padding:34px 48px 0;">
              <p style="margin:0 0 12px;font-family:Helvetica,Arial,sans-serif;font-size:13px;line-height:21px;color:#8a94a6;">
                If the button above doesn&rsquo;t work, copy and paste the following URL into your browser:
              </p>
              <div style="background-color:#f7f8fb;border:1px solid #e4e7ee;border-radius:8px;padding:14px 16px;word-break:break-all;font-family:'Courier New',Courier,monospace;font-size:13px;line-height:21px;color:#3a548f;">
                <%= verifyUrl %>
              </div>
            </td>
          </tr>

          <!-- HELP -->
          <tr>
            <td class="px" style="padding:34px 48px 44px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                <tr><td height="1" style="height:1px;background-color:#e4e7ee;font-size:0;line-height:0;">&nbsp;</td></tr>
              </table>
              <div style="margin-top:26px;font-family:Helvetica,Arial,sans-serif;font-size:15px;font-weight:700;color:#101c3a;">
                Need help?
              </div>
              <p style="margin:10px 0 0;font-family:Helvetica,Arial,sans-serif;font-size:14px;line-height:23px;color:#56607a;">
                If you experience any issues verifying your account, simply reply to this email and our support team will be glad to assist you.
              </p>
            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td align="center" style="background-color:#0f1b3d;padding:30px 40px;">
              <div style="font-family:Georgia,'Times New Roman',serif;font-size:17px;font-weight:700;color:#ffffff;">
                GovernanceFund
              </div>

              <p style="margin:20px 0 0;font-family:Helvetica,Arial,sans-serif;font-size:12px;line-height:20px;color:#7585a6;">
                &copy; <%= year %> GovernanceFund. All rights reserved.
              </p>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>